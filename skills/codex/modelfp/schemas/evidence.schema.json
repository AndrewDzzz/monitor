{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ModelFP Evidence Node",
  "type": "object",
  "required": ["id", "type", "severity", "source", "run_context"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(R|C|S|CODE|ENV|E|H|CR|G|LIT)[0-9A-Za-z_-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "repo_finding",
        "config_finding",
        "static_artifact_finding",
        "code_finding",
        "environment_finding",
        "runtime_event",
        "harm_chain",
        "literature_grounding",
        "candidate_rule",
        "gpt_summary"
      ]
    },
    "evidence_type": {
      "type": "string",
      "description": "Collector-native evidence class retained for backwards compatibility."
    },
    "source": {
      "type": "string",
      "examples": ["modelscan", "config_checker", "strace", "python_audit", "env_checker", "gpt_auditor"]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "finding": {
      "type": "string"
    },
    "meaning": {
      "type": "string"
    },
    "file": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": ["REPO", "CONFIG", "STATIC_ARTIFACT", "CODE", "ENV", "LOAD", "LOAD_AND_INFERENCE", "INFERENCE", "POSTPROCESS", "CLEANUP", "UNKNOWN"]
    },
    "pid": {
      "type": "integer"
    },
    "ppid": {
      "type": "integer"
    },
    "time": {
      "type": "number"
    },
    "op": {
      "type": "string",
      "examples": ["open", "read", "write", "connect", "execve", "import", "subprocess.Popen"]
    },
    "path": {
      "type": "string"
    },
    "path_class": {
      "type": "string",
      "enum": ["model_file", "library", "cache", "secret", "system", "system_sensitive", "docker_socket", "shell", "tmp_executable", "unknown"]
    },
    "mode": {
      "type": "string"
    },
    "fd": {
      "type": "integer"
    },
    "dst_type": {
      "type": "string",
      "enum": ["local", "private", "internal", "external", "unix_socket", "unknown"]
    },
    "port": {
      "type": "integer"
    },
    "result": {
      "type": "string",
      "enum": ["success", "failure", "observed", "unknown"]
    },
    "error": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {"type": "string"}
    },
    "raw_ref": {
      "type": "object",
      "properties": {
        "file": {"type": "string"},
        "line": {"type": "integer"},
        "offset": {"type": "integer"}
      }
    },
    "run_context": {
      "type": "object",
      "required": ["model", "revision", "run_id"],
      "properties": {
        "model": {"type": "string"},
        "revision": {"type": "string"},
        "run_id": {"type": "string"}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "supports_evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "supports_certificates": {
      "type": "array",
      "items": {"type": "string"}
    },
    "paper_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "method_tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "not_primary_evidence": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
